# Application settings
ASPNETCORE_ENVIRONMENT=Production
ConnectionStrings__Postgres=Host=localhost;Port=5432;Database=authorsbooks;Username=postgres;Password=postgres
ConnectionStrings__ApplicationInsights=

# Image settings
ACR_NAME=your-acr-name
ACR_LOGIN_SERVER=your-acr-name.azurecr.io
IMAGE_NAME=books-service-dotnet
IMAGE_TAG=latest
DOCKERFILE_PATH=Dockerfile
BUILD_CONTEXT=.

# Deployment settings
VM_IP=127.0.0.1
VM_USER=azureuser
REMOTE_DIR=/opt/books-service
