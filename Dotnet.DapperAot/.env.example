# Application settings
ASPNETCORE_ENVIRONMENT=Production
ConnectionStrings__Postgres=Host=localhost;Port=5432;Database=authorsbooks_dapper;Username=postgres;Password=postgres
ConnectionStrings__ApplicationInsights=
Database__MaxConnections=10
Telemetry__Enabled=true
Telemetry__OtlpEndpoint=http://otel-collector:4318/v1/traces

# Image settings
ACR_LOGIN_SERVER=your-acr-name.azurecr.io
IMAGE_NAME=books-service-dotnet-dapper-aot
IMAGE_TAG=latest
DOCKERFILE_PATH=Dockerfile
BUILD_CONTEXT=.

# Deployment settings
VM_IP=127.0.0.1
VM_USER=azureuser
REMOTE_DIR=/opt/books-service-dapper-aot
