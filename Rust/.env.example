API_IMAGE=rust-backend-service:local

APP__SERVER__HOST=0.0.0.0
APP__SERVER__PORT=8080
APP__DATABASE__CONNECTION_STRING=postgres://postgres:replace-with-local-password@postgres:5432/library
APP__DATABASE__MAX_CONNECTIONS=10
APP__DATABASE__RUN_MIGRATIONS_ON_STARTUP=true
APP__OBSERVABILITY__SERVICE_NAME=rust_backend_service
APP__OBSERVABILITY__ENVIRONMENT=local
APP__OBSERVABILITY__LOG_FILTER=info,rust_backend_service=debug,tower_http=info
APP__OBSERVABILITY__APPLICATION_INSIGHTS_CONNECTION_STRING=

POSTGRES_DB=library
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-local-password
