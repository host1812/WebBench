# Application settings
ASPNETCORE_ENVIRONMENT=Production
BOOKSVC_HTTP_ADDRESS=http://+:8080
BOOKSVC_DATABASE_CONNECTION_STRING=Host=your-managed-postgres-host.postgres.database.azure.com;Port=5432;Database=books_simple;Username=your-user;Password=your-password;SSL Mode=Require;Trust Server Certificate=true
BOOKSVC_DATABASE_MAX_CONNECTIONS=10
BOOKSVC_SERVICE_NAME=books-service
MIGRATIONS_DATABASE_CONNECTION_STRING=

# Image settings
ACR_NAME=your-acr-name
ACR_LOGIN_SERVER=your-acr-name.azurecr.io
IMAGE_NAME=books-service-dotnet-simple-aot
IMAGE_TAG=latest
DOCKERFILE_PATH=Dockerfile
BUILD_CONTEXT=.

# Deployment settings
VM_IP=127.0.0.1
VM_USER=azureuser
REMOTE_DIR=/opt/books-service-dotnet-simple-aot
